{
  "name": "carrent",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "node apps/desktop/node_modules/electron/install.js",
    "dev": "turbo dev",
    "dev:desktop": "cd apps/desktop && bun run dev",
    "dev:web": "cd apps/landing && bun run dev",
    "build": "turbo build",
    "lint": "turbo lint && bunx prettier --check .",
    "typecheck": "turbo typecheck",
    "format": "bunx prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3"
  }
}
