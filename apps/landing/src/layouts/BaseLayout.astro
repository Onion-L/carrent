---
import "@carrent/ui/tokens.css";
import "@carrent/ui/globals.css";
import "../styles/tailwind.css";

interface Props {
  title?: string;
}

const { title = "Carrent" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <meta
      content="Shared desktop and marketing system for a Carrent Electron and Astro monorepo."
      name="description"
    />
    <title>{title}</title>
  </head>
  <body class="font-sans antialiased">
    <slot />
  </body>
</html>

