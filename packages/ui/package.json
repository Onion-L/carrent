{
  "name": "@carrent/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./globals.css": "./src/styles/globals.css",
    "./tokens.css": "./src/styles/tokens.css"
  },
  "files": [
    "src"
  ],
  "peerDependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "scripts": {
    "build": "bun --eval \"import { mkdir } from 'node:fs/promises'; await mkdir('out', { recursive: true }); await Bun.write('out/.stamp', 'source package\\n'); console.log('No build step for @carrent/ui')\"",
    "lint": "bunx prettier --check .",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "format": "bunx prettier --write ."
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}
