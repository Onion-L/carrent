{
  "name": "carrent",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "node apps/desktop/node_modules/electron/install.js",
    "dev": "turbo dev",
    "dev:desktop": "cd apps/desktop && bun run dev",
    "dev:web": "cd apps/landing && bun run dev",
    "build": "turbo build",
    "lint": "oxlint .",
    "typecheck": "turbo typecheck",
    "fmt": "oxfmt . --write"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.11"
}
